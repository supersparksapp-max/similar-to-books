---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | Similar To Books" description="The page you're looking for doesn't exist.">
  <div class="max-w-3xl mx-auto px-8 py-32 text-center">
    <h1 class="text-6xl font-serif italic text-[#1C1917] mb-6">404</h1>
    <p class="font-serif text-xl text-[#404943] mb-10">The page you're looking for doesn't exist yet.</p>
    <a href="/" class="inline-block bg-[#2d6a4f] text-white font-sans text-sm tracking-widest uppercase font-medium py-3 px-10 rounded-md hover:opacity-90 transition-opacity no-underline">
      Back to Home
    </a>
  </div>
</BaseLayout>
