---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SEOHead from "../../components/SEOHead.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getAllAuthors, getAuthorBySlug } from "../../utils/sanity";
import { urlFor } from "../../utils/seo";

export async function getStaticPaths() {
  const authors = await getAllAuthors();
  if (!authors || authors.length === 0) return [];
  return authors
    .filter((author: any) => author.slug)
    .map((author: any) => ({
      params: { slug: author.slug },
    }));
}

const { slug } = Astro.params;
const author = await getAuthorBySlug(slug!);

if (!author) {
  return Astro.redirect("/404");
}

const seoTitle =
  author.seoTitle ?? `${author.name} Books & Recommendations`;
const seoDescription =
  author.seoDescription ??
  `Discover books by ${author.name} and find similar recommendations for every title.`;
const canonicalUrl = `https://www.similartobooks.com/author/${author.slug}`;
const ogImage = author.image
  ? urlFor(author.image).width(1200).height(630).fit("crop").url()
  : undefined;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: author.name, href: `/author/${author.slug}` },
];

const publishedBooks = author.books
  ? author.books.filter((b: any) => b.status === "published")
  : [];
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
    ogImage={ogImage}
  />

  <div class="max-w-6xl mx-auto px-4 py-16">
    <Breadcrumbs items={breadcrumbItems} />

    <!-- Author Header -->
    <div class="flex items-center gap-6 mb-10">
      {author.image && (
        <img
          src={urlFor(author.image).width(96).height(96).fit("crop").url()}
          alt={`${author.name}`}
          width="96"
          height="96"
          class="rounded-full grayscale w-24 h-24 object-cover shadow-editorial"
        />
      )}
      <div>
        <h1 class="font-serif text-4xl font-bold tracking-tight">
          {author.name}
        </h1>
      </div>
    </div>

    {author.bio && (
      <p class="text-on-surface-variant leading-relaxed text-lg max-w-3xl mb-16">
        {author.bio}
      </p>
    )}

    <!-- Books Grid -->
    {author.books && author.books.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl tracking-tight mb-8">
          Books by {author.name}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
          {author.books.map((book: any) => (
            <div class="bg-[#F2EFE9] rounded-2xl p-8 flex flex-col items-center text-center group hover:shadow-card transition-shadow">
              {book.coverImage ? (
                <a href={`/discover/${book.slug}`} class="mb-6 block">
                  <img
                    src={urlFor(book.coverImage).width(300).height(450).fit("crop").url()}
                    alt={`${book.title} by ${author.name} book cover`}
                    width="180"
                    height="270"
                    loading="lazy"
                    class="mx-auto rounded-lg shadow-book group-hover:shadow-lg transition-shadow"
                  />
                </a>
              ) : (
                <div class="w-[180px] h-[270px] bg-surface-container rounded-lg flex items-center justify-center mb-6 text-sm text-on-surface-variant">
                  <span>{book.title}</span>
                </div>
              )}
              <h3 class="font-serif text-lg font-bold mb-1 leading-snug">
                <a href={`/discover/${book.slug}`} class="hover:text-[#2d6a4f] transition-colors">
                  {book.title}
                </a>
              </h3>
              <p class="text-sm text-on-surface-variant italic mb-3">
                {author.name}
              </p>
              {book.status === "published" && (
                <a
                  href={`/discover/${book.slug}`}
                  class="text-sm text-[#0f5238] font-medium hover:underline"
                >
                  If you loved this, try &rarr;
                </a>
              )}
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
