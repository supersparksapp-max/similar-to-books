---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SEOHead from "../../components/SEOHead.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getAllSeries, getSeriesBySlug } from "../../utils/sanity";
import { urlFor } from "../../utils/seo";

export async function getStaticPaths() {
  const allSeries = await getAllSeries();
  if (!allSeries || allSeries.length === 0) return [];
  return allSeries
    .filter((series: any) => series.slug)
    .map((series: any) => ({
      params: { slug: series.slug },
    }));
}

const { slug } = Astro.params;
const series = await getSeriesBySlug(slug!);

if (!series) {
  return Astro.redirect("/404");
}

const seoTitle =
  series.seoTitle ?? `${series.name} Series - Reading Order`;
const seoDescription =
  series.seoDescription ??
  `Complete reading order for the ${series.name} series. Find all books in order and discover similar reads.`;
const canonicalUrl = `https://www.similartobooks.com/series/${series.slug}`;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: `${series.name} Series`, href: `/series/${series.slug}` },
];
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
  />

  <div class="max-w-6xl mx-auto px-4 py-16">
    <Breadcrumbs items={breadcrumbItems} />

    <h1 class="font-serif text-4xl tracking-tight mb-4">
      {series.name} Series - Reading Order
    </h1>

    {series.description && (
      <p class="text-on-surface-variant leading-relaxed text-lg max-w-3xl mb-16">
        {series.description}
      </p>
    )}

    {series.books && series.books.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
        {series.books.map((book: any, index: number) => (
          <div class="bg-[#F2EFE9] rounded-2xl p-8 flex flex-col items-center text-center group hover:shadow-card transition-shadow relative">
            {/* Series number badge */}
            <div class="absolute -top-3 -left-3 w-10 h-10 rounded-full bg-[#2d6a4f] text-white flex items-center justify-center font-bold text-sm shadow-editorial">
              #{book.seriesOrder ?? index + 1}
            </div>
            {book.coverImage ? (
              <a href={`/discover/${book.slug}`} class="mb-6 block">
                <img
                  src={urlFor(book.coverImage).width(300).height(450).fit("crop").url()}
                  alt={`${book.title} by ${book.author?.name ?? "Unknown Author"} book cover`}
                  width="180"
                  height="270"
                  loading="lazy"
                  class="mx-auto rounded-lg shadow-book group-hover:shadow-lg transition-shadow"
                />
              </a>
            ) : (
              <div class="w-[180px] h-[270px] bg-surface-container rounded-lg flex items-center justify-center mb-6 text-sm text-on-surface-variant">
                <span>{book.title}</span>
              </div>
            )}
            <h3 class="font-serif text-lg font-bold mb-1 leading-snug">
              {book.status === "published" ? (
                <a href={`/discover/${book.slug}`} class="hover:text-[#2d6a4f] transition-colors">
                  {book.title}
                </a>
              ) : (
                <span>{book.title}</span>
              )}
            </h3>
            {book.author && (
              <p class="text-sm text-on-surface-variant italic mb-3">
                {book.status === "published" ? (
                  <a href={`/author/${book.author.slug}`} class="hover:text-[#0f5238] transition-colors">
                    {book.author.name}
                  </a>
                ) : (
                  <span>{book.author.name}</span>
                )}
              </p>
            )}
            {book.status === "published" && (
              <a
                href={`/discover/${book.slug}`}
                class="text-sm text-[#0f5238] font-medium hover:underline"
              >
                If you loved this, try &rarr;
              </a>
            )}
          </div>
        ))}
      </div>
    ) : (
      <p class="text-on-surface-variant italic">
        No books added to this series yet. Check back soon!
      </p>
    )}
  </div>
</BaseLayout>
