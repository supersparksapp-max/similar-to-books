---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SEOHead from "../../components/SEOHead.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getAllTags, getTagBySlug } from "../../utils/sanity";
import { urlFor } from "../../utils/seo";

export async function getStaticPaths() {
  const tags = await getAllTags();
  if (!tags || tags.length === 0) return [];
  return tags
    .filter((tag: any) => tag.slug)
    .map((tag: any) => ({
      params: { slug: tag.slug },
    }));
}

const { slug } = Astro.params;
const tag = await getTagBySlug(slug!);

if (!tag) {
  return Astro.redirect("/404");
}

const seoTitle = tag.seoTitle ?? `${tag.name} Books`;
const seoDescription =
  tag.seoDescription ??
  `Browse books tagged with "${tag.name}" and find curated recommendations for each title.`;
const canonicalUrl = `https://www.similartobooks.com/tag/${tag.slug}/`;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: tag.name, href: `/tag/${tag.slug}/` },
];
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
  />

  <div class="max-w-6xl mx-auto px-4 py-16">
    <Breadcrumbs items={breadcrumbItems} />

    <h1 class="font-serif text-4xl tracking-tight mb-4">
      {tag.name} Books
    </h1>

    {tag.description && (
      <p class="text-on-surface-variant leading-relaxed text-lg max-w-3xl mb-16">
        {tag.description}
      </p>
    )}

    {tag.books && tag.books.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
        {tag.books.map((book: any) => (
          <div class="bg-[#F2EFE9] rounded-2xl p-8 flex flex-col items-center text-center group hover:shadow-card transition-shadow">
            {book.coverImage ? (
              <a href={`/discover/${book.slug}/`} class="mb-6 block">
                <img
                  src={urlFor(book.coverImage).width(300).height(450).fit("crop").url()}
                  alt={`${book.title} by ${book.author?.name ?? "Unknown Author"} book cover`}
                  width="180"
                  height="270"
                  loading="lazy"
                  class="mx-auto rounded-lg shadow-book group-hover:shadow-lg transition-shadow"
                />
              </a>
            ) : (
              <div class="w-[180px] h-[270px] bg-surface-container rounded-lg flex items-center justify-center mb-6 text-sm text-on-surface-variant">
                <span>{book.title}</span>
              </div>
            )}
            <h3 class="font-serif text-lg font-bold mb-1 leading-snug">
              <a href={`/discover/${book.slug}/`} class="hover:text-[#2d6a4f] transition-colors">
                {book.title}
              </a>
            </h3>
            {book.author && (
              <p class="text-sm text-on-surface-variant italic mb-3">
                {book.author.slug ? (
                  <a href={`/author/${book.author.slug}/`} class="hover:text-[#0f5238] transition-colors">
                    {book.author.name}
                  </a>
                ) : (
                  <span>{book.author.name}</span>
                )}
              </p>
            )}
            <a
              href={`/discover/${book.slug}/`}
              class="text-sm text-[#0f5238] font-medium hover:underline"
            >
              If you loved this, try &rarr;
            </a>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-on-surface-variant italic">
        No published books with this tag yet. Check back soon!
      </p>
    )}
  </div>
</BaseLayout>
