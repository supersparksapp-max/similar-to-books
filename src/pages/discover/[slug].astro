---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SEOHead from "../../components/SEOHead.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BookCard from "../../components/BookCard.astro";
import { PortableText } from "astro-portabletext";
import { getPublishedBooks, getBookBySlug } from "../../utils/sanity";
import {
  urlFor,
  generateBookSchema,
  generateItemListSchema,
} from "../../utils/seo";

export async function getStaticPaths() {
  const books = await getPublishedBooks();
  if (!books || books.length === 0) return [];
  return books
    .filter((book: any) => book.slug)
    .map((book: any) => ({
      params: { slug: book.slug },
    }));
}

const { slug } = Astro.params;
const book = await getBookBySlug(slug!);

if (!book) {
  return Astro.redirect("/404");
}

const currentYear = new Date().getFullYear();
const recCount = book.recommendations?.length ?? 0;
const authorName = book.author?.name ?? "Unknown Author";
const primaryGenre =
  book.genres && book.genres.length > 0 ? book.genres[0] : null;

const seoTitle =
  book.seoTitle ??
  `${recCount} Books Like ${book.title} by ${authorName} (${currentYear})`;
const seoDescription =
  book.seoDescription ??
  `Looking for books like ${book.title} by ${authorName}? Here are ${recCount} books similar to ${book.title} that share the same themes, style, and appeal.`;
const canonicalUrl = `https://www.similartobooks.com/discover/${book.slug}`;
const ogImage = book.coverImage
  ? urlFor(book.coverImage).width(1200).height(630).fit("crop").url()
  : undefined;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  ...(primaryGenre
    ? [{ label: primaryGenre.name, href: `/genre/${primaryGenre.slug}` }]
    : []),
  { label: `Books Like ${book.title}`, href: `/discover/${book.slug}` },
];

const sortedRecommendations = (book.recommendations ?? []).sort(
  (a: any, b: any) => (a.rank ?? 999) - (b.rank ?? 999)
);

const bookSchema = generateBookSchema(book);
const itemListSchema = generateItemListSchema(sortedRecommendations, book);

const heroImageUrl = book.coverImage
  ? urlFor(book.coverImage).width(600).height(900).fit("crop").url()
  : null;

const year = book.publishedDate
  ? new Date(book.publishedDate).getFullYear()
  : null;

// Build genre/tag string for the meta line
const genreNames = book.genres?.map((g: any) => g.name) ?? [];
const metaTagParts = [
  year,
  ...genreNames,
].filter(Boolean);
const metaTagString = metaTagParts.join(" \u2022 ").toUpperCase();

// Extract first paragraph for intro quote
let introQuote = "";
if (book.introContent && book.introContent.length > 0) {
  const firstBlock = book.introContent[0];
  if (firstBlock?.children) {
    introQuote = firstBlock.children.map((c: any) => c.text).join("");
  }
}

const authorImageUrl = book.author?.image
  ? urlFor(book.author.image).width(128).height(128).fit("crop").url()
  : null;
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
    ogImage={ogImage}
    ogType="article"
  />

  <main class="max-w-5xl mx-auto px-6 pt-4 md:pt-6">

    {/* ------------------------------------------------------------------ */}
    {/* Compact Hero Section                                                */}
    {/* ------------------------------------------------------------------ */}
    <section class="mb-12 md:mb-16">
      {/* Desktop: inline cover + title */}
      <div class="flex flex-col md:flex-row items-start md:items-end gap-6 mb-8">
        {/* Small tilted cover - desktop only */}
        <div class="hidden md:block w-24 md:w-32 shrink-0 shadow-lg rotate-[-2deg] bg-[#efeeea] overflow-hidden rounded-sm">
          {heroImageUrl ? (
            <img
              src={heroImageUrl}
              alt={`${book.title} by ${authorName} book cover`}
              class="w-full h-auto block aspect-[2/3] object-cover"
              loading="eager"
            />
          ) : (
            <div class="w-full aspect-[2/3] bg-[#e5e2dc] flex items-center justify-center p-4">
              <span class="font-serif text-sm text-[#404943] text-center">{book.title}</span>
            </div>
          )}
        </div>

        <div class="flex-1">
          {(year || primaryGenre) && (
            <div class="font-sans text-[11px] uppercase tracking-[0.2em] text-[#0f5238] font-bold mb-2 flex flex-wrap items-center gap-1">
              {year && <span>{year}</span>}
              {year && primaryGenre && <span class="mx-1">&bull;</span>}
              {primaryGenre && (
                <a href={`/genre/${primaryGenre.slug}`} class="hover:underline no-underline">{primaryGenre.name}</a>
              )}
              {book.genres && book.genres.length > 1 && book.genres.slice(1).map((genre: any) => (
                <><span class="mx-1">&bull;</span><a href={`/genre/${genre.slug}`} class="hover:underline no-underline">{genre.name}</a></>
              ))}
            </div>
          )}
          <h2 class="font-serif text-4xl md:text-5xl font-bold tracking-tight text-[#1C1917] leading-tight mb-2">
            {book.title}
          </h2>
          <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-stone-500 font-semibold">
            BY {book.author ? (
              <a href={`/author/${book.author.slug}`} class="hover:text-[#0f5238] transition-colors no-underline hover:underline">
                {authorName.toUpperCase()}
              </a>
            ) : (
              authorName.toUpperCase()
            )}
          </p>
        </div>
      </div>

      {/* Mobile: full cover image */}
      <div class="md:hidden mb-8">
        {heroImageUrl ? (
          <div class="relative w-full aspect-[2/3] rounded-lg overflow-hidden shadow-[0_8px_32px_-4px_rgba(28,25,23,0.08)] bg-[#f5f3ef]">
            <img
              src={heroImageUrl}
              alt={`${book.title} by ${authorName} book cover`}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        ) : (
          <div class="w-full aspect-[2/3] bg-[#e5e2dc] rounded-lg flex items-center justify-center p-8">
            <span class="font-serif text-2xl text-[#404943] text-center">{book.title}</span>
          </div>
        )}
      </div>

      {/* Intro text */}
      <div class="py-8 border-t border-stone-200/40">
        {introQuote ? (
          <div class="space-y-4">
            <p class="text-lg font-serif leading-relaxed text-[#404943]">
              {introQuote}
            </p>
          </div>
        ) : (
          <p class="text-lg font-serif leading-relaxed text-[#404943]">
            Discover the best books like {book.title} by {authorName}. These carefully selected recommendations share similar themes, writing style, and appeal.
          </p>
        )}
      </div>
    </section>

    {/* ------------------------------------------------------------------ */}
    {/* Recommendations Section                                             */}
    {/* ------------------------------------------------------------------ */}
    {sortedRecommendations.length > 0 && (
      <section>
        {/* Desktop H1 */}
        <div class="hidden md:block mb-10">
          <h1 class="font-serif text-2xl font-bold text-[#1C1917] pb-4 border-b border-stone-200/60">
            {recCount} Books Like {book.title}
          </h1>
        </div>
        {/* Mobile H1 */}
        <div class="md:hidden mb-12">
          <h1 class="text-2xl font-serif font-bold text-[#1C1917] tracking-tight border-l-4 border-[#0f5238] pl-4">
            {recCount} Books Like {book.title}
          </h1>
        </div>

        <div class="space-y-20 mb-24">
          {sortedRecommendations.map((rec: any) => (
            <BookCard
              book={rec.book}
              writeup={rec.writeup}
              rank={rec.rank ?? 0}
              commonElements={rec.commonElements}
              parentBookTitle={book.title}
            />
          ))}
        </div>
      </section>
    )}

    {/* ------------------------------------------------------------------ */}
    {/* About These Recommendations (moved to bottom)                       */}
    {/* ------------------------------------------------------------------ */}
    {book.introContent && book.introContent.length > 1 && (
      <section class="mb-24 md:mb-32 pt-16 border-t border-stone-200/40">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-[#1C1917] mb-8">Why These Books Are Similar to {book.title}</h2>
        <div class="about-content font-serif text-lg leading-relaxed text-[#404943] space-y-6 max-w-3xl">
          <PortableText value={book.introContent.slice(1)} />
        </div>
      </section>
    )}

    {/* ------------------------------------------------------------------ */}
    {/* Author Bio Section                                                  */}
    {/* ------------------------------------------------------------------ */}
    {book.author && (
      <section class="border-t border-stone-200/40 pt-16 mb-24">
        <div class="max-w-3xl mx-auto">
          <div class="flex items-center gap-5 mb-6">
            {authorImageUrl ? (
              <img
                src={authorImageUrl}
                alt={authorName}
                class="w-24 h-24 lg:w-32 lg:h-32 rounded-full object-cover grayscale"
                loading="lazy"
              />
            ) : (
              <div class="w-24 h-24 lg:w-32 lg:h-32 rounded-full bg-[#e5e2dc] flex items-center justify-center flex-shrink-0">
                <span class="font-serif text-2xl text-[#404943]">
                  {authorName.charAt(0)}
                </span>
              </div>
            )}
            <div>
              <h3 class="text-2xl font-bold italic font-serif text-[#1C1917] mb-1">
                {authorName}
              </h3>
              {book.author.bio && (
                <p class="font-sans text-sm text-[#404943] leading-relaxed max-w-xl">
                  {book.author.bio}
                </p>
              )}
            </div>
          </div>

          <a
            href={`/author/${book.author.slug}`}
            class="inline-block border border-[#0f5238] text-[#0f5238] font-sans text-[11px] font-bold uppercase tracking-[0.2em] px-8 py-3 rounded-sm hover:bg-[#0f5238] hover:text-white transition-all duration-200"
          >
            Explore More Books
          </a>
        </div>
      </section>
    )}

    {/* Breadcrumbs at bottom */}
    <Breadcrumbs items={breadcrumbItems} />

  </main>

  {/* JSON-LD */}
  <script
    type="application/ld+json"
    set:html={JSON.stringify(bookSchema)}
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(itemListSchema)}
  />
</BaseLayout>

<style>
  .about-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .about-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .about-content :global(a) {
    color: #0f5238;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .about-content :global(a:hover) {
    color: #2d6a4f;
  }

  .about-content :global(strong) {
    font-weight: 700;
  }

  .about-content :global(em) {
    font-style: italic;
  }
</style>
