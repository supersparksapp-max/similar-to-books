---
import BaseLayout from "../layouts/BaseLayout.astro";
import SEOHead from "../components/SEOHead.astro";
import { getPublishedBooks, getAllGenres, getAllTags } from "../utils/sanity";
import { urlFor } from "../utils/seo";

const books = await getPublishedBooks();
const genres = await getAllGenres();
const tags = await getAllTags();

const seoTitle = "Similar To Books - Find Your Next Great Read";
const seoDescription =
  "Discover books similar to your favorites. Browse curated recommendations by genre, author, and theme to find your next great read.";
const canonicalUrl = "https://www.similartobooks.com/";
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
    ogType="website"
  />

  <h1>Find Books Similar To Your Favorites</h1>

  <p class="intro">
    Looking for your next great read? We curate hand-picked book recommendations
    based on the titles you already love. Browse our collection below or explore
    by genre to discover books with similar themes, writing styles, and appeal.
  </p>

  {
    books && books.length > 0 && (
      <section class="book-grid-section">
        <h2>Browse All Recommendations</h2>
        <div class="book-grid">
          {books.map((book: any, index: number) => (
            <a href={`/${book.slug}`} class="book-grid__item">
              {book.coverImage ? (
                <img
                  src={urlFor(book.coverImage)
                    .width(300)
                    .height(450)
                    .fit("crop")
                    .url()}
                  alt={`${book.title} book cover`}
                  width="200"
                  height="300"
                  loading={index < 2 ? "eager" : "lazy"}
                />
              ) : (
                <div class="book-grid__placeholder">
                  <span>{book.title}</span>
                </div>
              )}
              <h3>{book.title}</h3>
              <span class="book-grid__cta">
                Books Like {book.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    )
  }

  {
    genres && genres.length > 0 && (
      <section class="browse-section">
        <h2>Browse by Genre</h2>
        <div class="tag-list">
          {genres.map((genre: any) => (
            <a href={`/genre/${genre.slug}`} class="tag-link">
              {genre.name}
            </a>
          ))}
        </div>
      </section>
    )
  }

  {
    tags && tags.length > 0 && (
      <section class="browse-section">
        <h2>Browse by Tag</h2>
        <div class="tag-list">
          {tags.map((tag: any) => (
            <a href={`/tag/${tag.slug}`} class="tag-link tag-link--secondary">
              {tag.name}
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  h1 {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    text-align: center;
    line-height: 1.2;
  }

  .intro {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 2.5rem;
    color: #4b5563;
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .book-grid-section {
    margin-bottom: 3rem;
  }

  .book-grid-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .book-grid__item {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.15s;
  }

  .book-grid__item:hover {
    transform: translateY(-4px);
  }

  .book-grid__item img {
    width: 100%;
    max-width: 200px;
    height: auto;
    border-radius: 0.375rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    margin-bottom: 0.75rem;
  }

  .book-grid__placeholder {
    width: 200px;
    height: 300px;
    background: #f3f4f6;
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    color: #6b7280;
  }

  .book-grid__item h3 {
    font-size: 1rem;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .book-grid__cta {
    font-size: 0.8rem;
    color: #2563eb;
  }

  .browse-section {
    margin-bottom: 2.5rem;
  }

  .browse-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-link {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: #eff6ff;
    color: #2563eb;
    border-radius: 9999px;
    text-decoration: none;
    font-size: 0.9rem;
    border: 1px solid #bfdbfe;
    transition: background-color 0.15s;
  }

  .tag-link:hover {
    background: #dbeafe;
  }

  .tag-link--secondary {
    background: #f0fdf4;
    color: #16a34a;
    border-color: #bbf7d0;
  }

  .tag-link--secondary:hover {
    background: #dcfce7;
  }
</style>
