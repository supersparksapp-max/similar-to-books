---
import BaseLayout from "../layouts/BaseLayout.astro";
import SEOHead from "../components/SEOHead.astro";
import { getPublishedBooks, getAllGenres, getAllTags } from "../utils/sanity";
import { urlFor } from "../utils/seo";

const books = await getPublishedBooks();
const genres = await getAllGenres();
const tags = await getAllTags();

const featuredBook = books && books.length > 0 ? books[0] : null;

const seoTitle = "Similar To Books - Find Your Next Great Read";
const seoDescription =
  "Discover books similar to your favorites. Browse curated recommendations by genre, author, and theme to find your next great read.";
const canonicalUrl = "https://www.similartobooks.com/";
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
    ogType="website"
  />

  <!-- Hero Section -->
  <section class="max-w-5xl mx-auto py-32 md:py-48 text-center px-4">
    <h1 class="font-serif text-5xl md:text-7xl tracking-tighter leading-tight mb-6">
      Find Books Similar To Your Favorites
    </h1>
    <p class="font-serif text-lg md:text-xl max-w-2xl mx-auto opacity-80 mb-10">
      Hand-picked recommendations based on the titles you already love. Discover
      your next great read by browsing curated suggestions across every genre.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="#recommendations"
        class="inline-block bg-[#2d6a4f] text-white px-8 py-3.5 rounded-full font-medium hover:bg-[#0f5238] transition-colors"
      >
        Start Exploring
      </a>
      <a
        href="#genres"
        class="inline-block px-8 py-3.5 rounded-full font-medium border border-on-surface-variant hover:border-[#0f5238] transition-colors"
      >
        Search Archive
      </a>
    </div>
  </section>

  <!-- Featured Book Section -->
  {featuredBook && (
    <section class="max-w-6xl mx-auto px-4 pb-32">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-7">
          {featuredBook.coverImage ? (
            <a href={`/${featuredBook.slug}`} class="block group">
              <img
                src={urlFor(featuredBook.coverImage).width(800).height(1000).fit("crop").url()}
                alt={`${featuredBook.title} by ${featuredBook.author?.name ?? "Unknown Author"} book cover`}
                width="800"
                height="1000"
                class="w-full rounded-2xl shadow-book transition-all duration-500 group-hover:grayscale"
                loading="eager"
              />
            </a>
          ) : null}
        </div>
        <div class="md:col-span-5">
          <span class="inline-block text-xs font-medium uppercase tracking-widest text-[#954912] mb-4">
            Curator's Choice
          </span>
          <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-4">
            <a href={`/${featuredBook.slug}`} class="hover:text-[#2d6a4f] transition-colors">
              {featuredBook.title}
            </a>
          </h2>
          {featuredBook.description && (
            <p class="text-on-surface-variant leading-relaxed mb-6 line-clamp-4">
              {featuredBook.description}
            </p>
          )}
          <a
            href={`/${featuredBook.slug}`}
            class="inline-flex items-center gap-2 text-[#0f5238] font-medium hover:gap-3 transition-all"
          >
            Find similar books
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Browse All Recommendations -->
  {books && books.length > 0 && (
    <section id="recommendations" class="max-w-6xl mx-auto px-4 py-32">
      <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-12">
        Browse All Recommendations
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
        {books.map((book: any) => (
          <div class="bg-[#F2EFE9] rounded-2xl p-8 flex flex-col items-center text-center group hover:shadow-card transition-shadow">
            {book.coverImage ? (
              <a href={`/${book.slug}`} class="mb-6 block">
                <img
                  src={urlFor(book.coverImage).width(300).height(450).fit("crop").url()}
                  alt={`${book.title} by ${book.author?.name ?? "Unknown Author"} book cover`}
                  width="180"
                  height="270"
                  loading="lazy"
                  class="mx-auto rounded-lg shadow-book group-hover:shadow-lg transition-shadow"
                />
              </a>
            ) : (
              <div class="w-[180px] h-[270px] bg-surface-container rounded-lg flex items-center justify-center mb-6 text-sm text-on-surface-variant">
                <span>{book.title}</span>
              </div>
            )}
            <h3 class="font-serif text-lg font-bold mb-1 leading-snug">
              <a href={`/${book.slug}`} class="hover:text-[#2d6a4f] transition-colors">
                {book.title}
              </a>
            </h3>
            {book.author && (
              <p class="text-sm text-on-surface-variant italic mb-3">
                <a href={`/author/${book.author.slug}`} class="hover:text-[#0f5238] transition-colors">
                  {book.author.name}
                </a>
              </p>
            )}
            <a
              href={`/${book.slug}`}
              class="text-sm text-[#0f5238] font-medium hover:underline"
            >
              If you loved this, try &rarr;
            </a>
          </div>
        ))}
      </div>
      <div class="text-center mt-16">
        <a
          href="#genres"
          class="inline-block bg-[#2d6a4f] text-white px-8 py-3.5 rounded-full font-medium hover:bg-[#0f5238] transition-colors"
        >
          See All Recommendations
        </a>
      </div>
    </section>
  )}

  <!-- Browse by Genre -->
  {genres && genres.length > 0 && (
    <section id="genres" class="max-w-6xl mx-auto px-4 py-8">
      <div class="bg-[#f5f3ef] rounded-3xl py-20 px-8 md:px-16">
        <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-10 text-center">
          Browse by Genre
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {genres.map((genre: any) => (
            <a
              href={`/genre/${genre.slug}`}
              class="px-6 py-2.5 rounded-full bg-white border border-outline-variant text-on-surface text-sm font-medium hover:border-[#0f5238] hover:text-[#0f5238] transition-colors"
            >
              {genre.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Browse by Tag -->
  {tags && tags.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-20">
      <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-10 text-center">
        Browse by Tag
      </h2>
      <div class="flex flex-wrap justify-center gap-2">
        {tags.map((tag: any) => (
          <a
            href={`/tag/${tag.slug}`}
            class="px-4 py-2 rounded-lg bg-surface border border-outline-variant text-on-surface-variant text-sm hover:border-[#0f5238] hover:text-[#0f5238] transition-colors"
          >
            {tag.name}
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
