---
import BaseLayout from "../layouts/BaseLayout.astro";
import SEOHead from "../components/SEOHead.astro";
import { getPublishedBooks, getAllGenres, getAllTags } from "../utils/sanity";
import { urlFor } from "../utils/seo";

const books = await getPublishedBooks();
const genres = await getAllGenres();
const tags = await getAllTags();

const featuredBook = books && books.length > 0 ? books[0] : null;

const seoTitle = "Similar To Books - Find Your Next Great Read";
const seoDescription =
  "Discover books similar to your favorites. Browse curated recommendations by genre, author, and theme to find your next great read.";
const canonicalUrl = "https://www.similartobooks.com/";
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
    ogType="website"
  />

  <!-- Hero Section -->
  <section class="max-w-5xl mx-auto px-8 py-32 md:py-48 text-center">
    <h1 class="font-serif text-5xl md:text-7xl text-[#1C1917] leading-tight mb-8 tracking-tighter">
      Find Books Similar<br />To Your Favorites
    </h1>
    <p class="font-serif text-lg md:text-xl text-[#404943] max-w-2xl mx-auto leading-relaxed mb-12 opacity-80">
      Hand-picked recommendations based on the titles you already love. Discover
      your next great read by browsing curated suggestions across every genre.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="#recommendations"
        class="inline-block bg-[#2d6a4f] text-white px-8 py-3.5 rounded-full font-sans font-medium text-sm hover:bg-[#0f5238] transition-colors"
      >
        Start Exploring
      </a>
      <a
        href="#genres"
        class="inline-block px-8 py-3.5 rounded-full font-sans font-medium text-sm border border-[#707973] text-[#1C1917] hover:border-[#0f5238] hover:text-[#0f5238] transition-colors"
      >
        Search Archive
      </a>
    </div>
  </section>

  <!-- Featured Book Section -->
  {featuredBook && (
    <section class="max-w-7xl mx-auto px-8 py-20">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-7">
          {featuredBook.coverImage ? (
            <a href={`/${featuredBook.slug}`} class="block group">
              <img
                src={urlFor(featuredBook.coverImage).width(800).height(1000).fit("crop").url()}
                alt={`${featuredBook.title} by ${featuredBook.author?.name ?? "Unknown Author"} book cover`}
                width="800"
                height="1000"
                class="w-full rounded-2xl grayscale hover:grayscale-0 transition-all duration-700"
                loading="eager"
              />
            </a>
          ) : null}
        </div>
        <div class="md:col-span-5">
          <span class="inline-block font-sans text-xs font-medium uppercase tracking-widest text-[#954912] mb-4">
            Curator's Choice
          </span>
          <h2 class="font-serif text-3xl md:text-4xl tracking-tight text-[#1C1917] mb-4">
            <a href={`/${featuredBook.slug}`} class="hover:text-[#2d6a4f] transition-colors no-underline">
              {featuredBook.title}
            </a>
          </h2>
          {featuredBook.description && (
            <p class="font-serif text-[#404943] leading-relaxed mb-6 line-clamp-4">
              {featuredBook.description}
            </p>
          )}
          <a
            href={`/${featuredBook.slug}`}
            class="inline-flex items-center gap-2 text-[#0f5238] font-sans font-medium hover:gap-3 transition-all"
          >
            Find similar books
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Browse All Recommendations -->
  {books && books.length > 0 && (
    <section id="recommendations" class="max-w-7xl mx-auto px-8 py-32">
      <h2 class="font-serif text-3xl md:text-4xl tracking-tight text-[#1C1917] mb-12">
        Browse All Recommendations
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {books.map((book: any) => (
          <div class="bg-[#F2EFE9] p-10 rounded-lg transition-transform duration-500 hover:-translate-y-2">
            {book.coverImage ? (
              <a href={`/${book.slug}`} class="block mb-8">
                <img
                  src={urlFor(book.coverImage).width(300).height(450).fit("crop").url()}
                  alt={`${book.title} by ${book.author?.name ?? "Unknown Author"} book cover`}
                  width="192"
                  height="288"
                  loading="lazy"
                  class="w-48 mx-auto book-shadow"
                />
              </a>
            ) : (
              <div class="w-48 h-72 mx-auto bg-[#e5e2dc] rounded-sm flex items-center justify-center mb-8">
                <span class="font-serif text-sm text-[#404943] text-center px-4">{book.title}</span>
              </div>
            )}
            <h3 class="font-serif text-2xl text-[#1C1917] mb-1">
              <a href={`/${book.slug}`} class="hover:text-[#2d6a4f] transition-colors no-underline">
                {book.title}
              </a>
            </h3>
            {book.author && (
              <p class="font-serif text-sm text-[#404943]/80 italic mb-0">
                <a href={`/author/${book.author.slug}`} class="hover:text-[#0f5238] transition-colors no-underline">
                  {book.author.name}
                </a>
              </p>
            )}
            <hr class="border-[#bfc9c1]/20 my-6" />
            <a
              href={`/${book.slug}`}
              class="font-sans text-sm text-[#0f5238] font-medium hover:underline"
            >
              If you loved this, try &rarr;
            </a>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Browse by Genre -->
  {genres && genres.length > 0 && (
    <section id="genres" class="max-w-7xl mx-auto px-8 py-8">
      <div class="bg-[#f5f3ef] rounded-3xl py-20 px-8 md:px-16 mx-0">
        <h2 class="font-serif text-3xl md:text-4xl tracking-tight text-[#1C1917] mb-10 text-center">
          Browse by Genre
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {genres.map((genre: any) => (
            <a
              href={`/genre/${genre.slug}`}
              class="px-6 py-2.5 rounded-full bg-white border border-[#bfc9c1]/30 text-[#1C1917] font-sans text-sm hover:border-[#0f5238] hover:text-[#0f5238] transition-all"
            >
              {genre.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Browse by Tag -->
  {tags && tags.length > 0 && (
    <section class="max-w-7xl mx-auto px-8 py-20">
      <h2 class="font-serif text-3xl md:text-4xl tracking-tight text-[#1C1917] mb-10 text-center">
        Browse by Tag
      </h2>
      <div class="flex flex-wrap justify-center gap-2">
        {tags.map((tag: any) => (
          <a
            href={`/tag/${tag.slug}`}
            class="px-4 py-2 rounded-lg bg-[#FAF8F4] border border-[#2D6A4F]/10 text-[#1C1917] font-sans text-xs hover:border-[#0f5238] transition-all"
          >
            {tag.name}
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
