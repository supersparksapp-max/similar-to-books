---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SEOHead from "../../components/SEOHead.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getAllGenres, getGenreBySlug } from "../../utils/sanity";
import { urlFor } from "../../utils/seo";

export async function getStaticPaths() {
  const genres = await getAllGenres();
  if (!genres || genres.length === 0) return [];
  return genres.map((genre: any) => ({
    params: { slug: genre.slug },
  }));
}

const { slug } = Astro.params;
const genre = await getGenreBySlug(slug!);

if (!genre) {
  return Astro.redirect("/404");
}

const seoTitle =
  genre.seoTitle ?? `Best ${genre.name} Books & Recommendations`;
const seoDescription =
  genre.seoDescription ??
  `Discover the best ${genre.name} books and find similar reads. Browse our curated ${genre.name} recommendations.`;
const canonicalUrl = `https://www.similartobooks.com/genre/${genre.slug}`;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: genre.name, href: `/genre/${genre.slug}` },
];
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <SEOHead
    slot="head"
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
  />

  <Breadcrumbs items={breadcrumbItems} />

  <h1>Best {genre.name} Books</h1>

  {
    genre.description && (
      <div class="genre-description">
        <p>{genre.description}</p>
      </div>
    )
  }

  {
    genre.books && genre.books.length > 0 ? (
      <section class="book-grid-section">
        <div class="book-grid">
          {genre.books.map((book: any, index: number) => (
            <a href={`/${book.slug}`} class="book-grid__item">
              {book.coverImage ? (
                <img
                  src={urlFor(book.coverImage)
                    .width(300)
                    .height(450)
                    .fit("crop")
                    .url()}
                  alt={`${book.title} by ${book.author?.name ?? "Unknown"} book cover`}
                  width="200"
                  height="300"
                  loading={index < 2 ? "eager" : "lazy"}
                />
              ) : (
                <div class="book-grid__placeholder">
                  <span>{book.title}</span>
                </div>
              )}
              <h3>{book.title}</h3>
              {book.author && (
                <span class="book-grid__author">by {book.author.name}</span>
              )}
              <span class="book-grid__cta">
                Books Like {book.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    ) : (
      <p class="empty-state">
        No published books in this genre yet. Check back soon!
      </p>
    )
  }
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .genre-description {
    margin-bottom: 2rem;
    line-height: 1.7;
    color: #374151;
    font-size: 1.05rem;
    max-width: 700px;
  }

  .genre-description p {
    margin: 0;
  }

  .book-grid-section {
    margin-bottom: 2.5rem;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .book-grid__item {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.15s;
  }

  .book-grid__item:hover {
    transform: translateY(-4px);
  }

  .book-grid__item img {
    width: 100%;
    max-width: 200px;
    height: auto;
    border-radius: 0.375rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    margin-bottom: 0.75rem;
  }

  .book-grid__placeholder {
    width: 200px;
    height: 300px;
    background: #f3f4f6;
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    color: #6b7280;
  }

  .book-grid__item h3 {
    font-size: 1rem;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .book-grid__author {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 0.25rem;
  }

  .book-grid__cta {
    font-size: 0.8rem;
    color: #2563eb;
  }

  .empty-state {
    color: #6b7280;
    font-style: italic;
  }
</style>
