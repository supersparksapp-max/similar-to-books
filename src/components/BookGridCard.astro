---
import { urlFor } from "../utils/seo";

interface Props {
  book: {
    title: string;
    slug: string;
    coverImage?: any;
    author?: { name: string; slug: string };
    genres?: Array<{ name: string; slug: string }>;
  };
}

const { book } = Astro.props;

const coverUrl = book.coverImage
  ? urlFor(book.coverImage).width(400).height(600).fit("crop").url()
  : null;
---

<div class="group">
  <a href={`/discover/${book.slug}`} class="block">
    <div class="bg-[#F2EFE9] p-8 aspect-[2/3] mb-6 relative overflow-hidden flex items-center justify-center transition-transform duration-500 group-hover:-translate-y-2">
      {coverUrl ? (
        <img
          src={coverUrl}
          alt={`${book.title} by ${book.author?.name ?? ""} book cover`}
          class="w-full h-full object-cover book-shadow"
          loading="lazy"
        />
      ) : (
        <span class="font-serif text-sm text-[#404943] text-center px-4">{book.title}</span>
      )}
    </div>
  </a>
  {book.genres && book.genres.length > 0 && (
    <span class="font-sans text-[9px] tracking-[0.2em] uppercase font-bold text-[#0f5238] mb-2 block">
      {book.genres.map((g: any) => g.name).join(" / ")}
    </span>
  )}
  <h4 class="font-serif text-xl text-[#1C1917] mb-1">
    <a href={`/discover/${book.slug}`} class="hover:text-[#2d6a4f] transition-colors no-underline">{book.title}</a>
  </h4>
  {book.author && (
    <p class="font-sans text-xs text-[#404943] tracking-wider font-light">
      <a href={`/author/${book.author.slug}`} class="hover:text-[#0f5238] transition-colors no-underline">
        {book.author.name}
      </a>
    </p>
  )}
</div>
