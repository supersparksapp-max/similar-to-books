---
import { urlFor } from "../utils/seo";

interface BookData {
  title: string;
  slug: string;
  coverImage?: any;
  publishedDate?: string;
  publisher?: string;
  pageCount?: number;
  description?: string;
  amazonAffiliateLink?: string;
  author?: {
    name: string;
    slug: string;
  };
  genres?: Array<{
    name: string;
    slug: string;
  }>;
}

interface Props {
  book: BookData;
  writeup: string;
  rank: number;
  commonElements?: string[];
  parentBookTitle?: string;
}

const { book, writeup, rank, commonElements, parentBookTitle } = Astro.props;

const coverUrl = book.coverImage
  ? urlFor(book.coverImage).width(600).height(900).fit("crop").url()
  : null;

const mobileCoverUrl = book.coverImage
  ? urlFor(book.coverImage).width(800).height(500).fit("crop").url()
  : null;

const isLazyLoad = rank > 2;
const authorName = book.author?.name ?? "Unknown Author";
const year = book.publishedDate
  ? new Date(book.publishedDate).getFullYear()
  : null;
const primaryGenre =
  book.genres && book.genres.length > 0 ? book.genres[0] : null;

// Split writeup into paragraphs at sentence boundaries (roughly every 3-4 sentences)
function splitIntoParagraphs(text: string): string[] {
  const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
  if (sentences.length <= 3) return [text];

  const midpoint = Math.ceil(sentences.length / 2);
  return [
    sentences.slice(0, midpoint).join("").trim(),
    sentences.slice(midpoint).join("").trim(),
  ].filter(Boolean);
}

const paragraphs = splitIntoParagraphs(writeup);
---

<article
  class="card-shadow bg-[#F2EFE9] border border-black/5 p-8 lg:p-12 rounded-xl hover:bg-[#ebe8e2] hover:-translate-y-1 transition-all duration-300"
  id={`recommendation-${rank}`}
>
  <div class="flex flex-col md:flex-row gap-8 lg:gap-16 items-start">
    {/* Cover Image */}
    <div class="w-full md:w-1/4 flex-shrink-0">
      {coverUrl ? (
        <>
          {/* Mobile cover - full width 16:10 */}
          <img
            src={mobileCoverUrl}
            alt={`${book.title} by ${authorName} book cover`}
            loading={isLazyLoad ? "lazy" : "eager"}
            class="md:hidden w-full aspect-[16/10] object-cover rounded-sm"
          />
          {/* Desktop cover - portrait 2:3 */}
          <img
            src={coverUrl}
            alt={`${book.title} by ${authorName} book cover`}
            loading={isLazyLoad ? "lazy" : "eager"}
            class="hidden md:block w-full editorial-shadow rounded-sm aspect-[2/3] object-cover"
          />
        </>
      ) : (
        <div class="w-full aspect-[2/3] bg-[#e5e2dc] rounded-sm flex items-center justify-center p-6">
          <span class="font-serif text-[#404943] text-center text-sm">{book.title}</span>
        </div>
      )}
    </div>

    {/* Content */}
    <div class="flex-grow space-y-6">
      {/* Title */}
      <h3 class="text-3xl font-bold text-[#1C1917] font-serif">
        <a href={`/${book.slug}`} class="hover:text-[#0f5238] transition-colors no-underline">
          {book.title}
        </a>
      </h3>

      {/* Metadata tags */}
      <div class="flex flex-wrap gap-2">
        {book.author && (
          <a href={`/author/${book.author.slug}`} class="inline-block px-4 py-1.5 rounded bg-[#e5e2dc] font-sans text-[11px] tracking-widest uppercase text-[#404943] hover:text-[#0f5238] transition-colors no-underline">
            {authorName}
          </a>
        )}
        {year && (
          <span class="inline-block px-4 py-1.5 rounded bg-[#e5e2dc] font-sans text-[11px] tracking-widest uppercase text-[#404943]">
            {year}
          </span>
        )}
        {primaryGenre && (
          <a href={`/genre/${primaryGenre.slug}`} class="inline-block px-4 py-1.5 rounded bg-[#e5e2dc] font-sans text-[11px] tracking-widest uppercase text-[#404943] hover:text-[#0f5238] transition-colors no-underline">
            {primaryGenre.name}
          </a>
        )}
      </div>

      {/* Why it's similar label */}
      <p class="font-sans text-[10px] uppercase tracking-widest font-bold text-[#0f5238]">
        Why it's similar
      </p>

      {/* Writeup */}
      <div class="text-lg text-[#1C1917] leading-relaxed font-serif">
        {paragraphs.map((para) => (
          <p class="mb-4 last:mb-0">{para}</p>
        ))}
      </div>

      {/* Common Elements */}
      {commonElements && commonElements.length > 0 && (
        <div class="border-l-2 border-[#2d6a4f]/30 pl-6 py-2">
          <h4 class="font-sans text-[10px] uppercase tracking-widest font-bold text-[#0f5238] mb-3">
            Elements in common with {parentBookTitle}
          </h4>
          <ul class="space-y-1.5 pl-0 list-none">
            {commonElements.map((element) => (
              <li class="flex items-start gap-2.5 font-serif text-sm text-[#404943] leading-relaxed">
                <span class="text-[#2d6a4f] mt-1.5 text-[8px]">&#9679;</span>
                {element}
              </li>
            ))}
          </ul>
        </div>
      )}

      {/* Buy on Amazon button */}
      {book.amazonAffiliateLink && (
        <a
          href={book.amazonAffiliateLink}
          target="_blank"
          rel="nofollow noopener sponsored"
          class="inline-flex items-center justify-center border border-[#0f5238] text-[#0f5238] font-sans text-[11px] font-bold uppercase tracking-[0.2em] px-10 py-4 rounded-sm hover:bg-[#0f5238] hover:text-white transition-all"
        >
          Buy on Amazon
        </a>
      )}
    </div>
  </div>
</article>
