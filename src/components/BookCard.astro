---
import { urlFor } from "../utils/seo";

interface BookData {
  title: string;
  slug: string;
  coverImage?: any;
  publishedDate?: string;
  publisher?: string;
  pageCount?: number;
  description?: string;
  amazonAffiliateLink?: string;
  author?: {
    name: string;
    slug: string;
  };
  genres?: Array<{
    name: string;
    slug: string;
  }>;
}

interface Props {
  book: BookData;
  writeup: string;
  rank: number;
  commonElements?: string[];
  parentBookTitle?: string;
}

const { book, writeup, rank, commonElements, parentBookTitle } = Astro.props;

const coverUrl = book.coverImage
  ? urlFor(book.coverImage).width(600).height(900).fit("crop").url()
  : null;

const mobileCoverUrl = book.coverImage
  ? urlFor(book.coverImage).width(800).height(500).fit("crop").url()
  : null;

const isLazyLoad = rank > 2;
const authorName = book.author?.name ?? "Unknown Author";
const year = book.publishedDate
  ? new Date(book.publishedDate).getFullYear()
  : null;
const primaryGenre =
  book.genres && book.genres.length > 0 ? book.genres[0] : null;

// Split writeup into paragraphs at sentence boundaries (roughly every 3-4 sentences)
function splitIntoParagraphs(text: string): string[] {
  const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
  if (sentences.length <= 3) return [text];

  const midpoint = Math.ceil(sentences.length / 2);
  return [
    sentences.slice(0, midpoint).join("").trim(),
    sentences.slice(midpoint).join("").trim(),
  ].filter(Boolean);
}

const paragraphs = splitIntoParagraphs(writeup);
---

<article
  class="card-shadow bg-[#F2EFE9] border border-black/5 p-8 lg:p-12 rounded-xl hover:bg-[#ebe8e2] hover:-translate-y-1 transition-all duration-300"
  id={`recommendation-${rank}`}
>
  <div class="flex flex-col md:flex-row md:gap-10 lg:gap-14">
    {/* Cover Image */}
    <div class="md:w-1/4 flex-shrink-0 mb-8 md:mb-0">
      {coverUrl ? (
        <>
          {/* Mobile cover - full width 16:10 */}
          <img
            src={mobileCoverUrl}
            alt={`${book.title} by ${authorName} book cover`}
            loading={isLazyLoad ? "lazy" : "eager"}
            class="md:hidden w-full aspect-[16/10] object-cover rounded-sm"
          />
          {/* Desktop cover - portrait 2:3 */}
          <img
            src={coverUrl}
            alt={`${book.title} by ${authorName} book cover`}
            loading={isLazyLoad ? "lazy" : "eager"}
            class="hidden md:block editorial-shadow rounded-sm aspect-[2/3] object-cover w-full"
          />
        </>
      ) : (
        <div class="w-full aspect-[2/3] bg-surface-container rounded-sm flex items-center justify-center p-6">
          <span class="font-serif text-on-surface-variant text-center text-sm">{book.title}</span>
        </div>
      )}
    </div>

    {/* Content */}
    <div class="flex-1 min-w-0">
      {/* Title */}
      <h3 class="text-3xl font-bold font-serif tracking-tight mb-4">
        <a href={`/${book.slug}`} class="text-on-background hover:text-primary transition-colors no-underline">
          {book.title}
        </a>
      </h3>

      {/* Metadata line */}
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-6 font-sans text-[11px] tracking-widest uppercase text-on-surface-variant">
        {book.author && (
          <a href={`/author/${book.author.slug}`} class="hover:text-primary transition-colors no-underline text-on-surface-variant">
            {authorName}
          </a>
        )}
        {year && (
          <>
            <span class="text-outline-variant">&middot;</span>
            <span>{year}</span>
          </>
        )}
        {primaryGenre && (
          <>
            <span class="text-outline-variant">&middot;</span>
            <a href={`/genre/${primaryGenre.slug}`} class="hover:text-primary transition-colors no-underline text-on-surface-variant">
              {primaryGenre.name}
            </a>
          </>
        )}
      </div>

      {/* Why it's similar label */}
      <p class="font-sans text-[10px] uppercase tracking-widest font-bold text-primary mb-3">
        Why it's similar
      </p>

      {/* Writeup */}
      <div class="font-serif text-lg leading-relaxed text-on-background/85 mb-8">
        {paragraphs.map((para) => (
          <p class="mb-4 last:mb-0">{para}</p>
        ))}
      </div>

      {/* Common Elements callout */}
      {commonElements && commonElements.length > 0 && (
        <div class="border-l-3 border-blue-600 bg-blue-50/60 rounded-r-md px-6 py-5 mb-8">
          <h4 class="font-sans text-[11px] uppercase tracking-widest font-bold text-blue-800 mb-3">
            Elements in common with {parentBookTitle}
          </h4>
          <ul class="list-disc pl-5 space-y-1">
            {commonElements.map((element) => (
              <li class="font-sans text-sm text-blue-900/80 leading-relaxed">{element}</li>
            ))}
          </ul>
        </div>
      )}

      {/* Buy on Amazon button */}
      {book.amazonAffiliateLink && (
        <a
          href={book.amazonAffiliateLink}
          target="_blank"
          rel="nofollow noopener sponsored"
          class="inline-block border border-primary text-primary font-sans text-[11px] font-bold uppercase tracking-[0.2em] px-10 py-4 rounded-sm hover:bg-primary hover:text-white transition-all duration-200"
        >
          Buy on Amazon
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .card-shadow {
    box-shadow:
      0 10px 40px -10px rgba(0, 0, 0, 0.04),
      0 0 1px 0 rgba(0, 0, 0, 0.1);
  }

  .editorial-shadow {
    box-shadow:
      0 4px 14px rgba(0, 0, 0, 0.1),
      0 2px 4px rgba(0, 0, 0, 0.06);
  }
</style>
