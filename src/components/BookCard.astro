---
import { urlFor } from "../utils/seo";

interface BookData {
  title: string;
  slug: string;
  coverImage?: any;
  publishedDate?: string;
  publisher?: string;
  pageCount?: number;
  description?: string;
  amazonAffiliateLink?: string;
  status?: string;
  author?: {
    name: string;
    slug: string;
  };
  genres?: Array<{
    name: string;
    slug: string;
  }>;
}

interface Props {
  book: BookData;
  writeup: string;
  rank: number;
  commonElements?: string[];
  parentBookTitle?: string;
}

const { book, writeup, rank, commonElements, parentBookTitle } = Astro.props;

const coverUrl = book.coverImage
  ? urlFor(book.coverImage).width(600).height(900).fit("crop").url()
  : null;

const isLazyLoad = rank > 2;
const authorName = book.author?.name ?? "Unknown Author";
const year = book.publishedDate
  ? new Date(book.publishedDate).getFullYear()
  : null;

const genreNames = book.genres?.map((g: any) => g.name) ?? [];

// Split writeup into 3-4 paragraphs at sentence boundaries
function splitIntoParagraphs(text: string): string[] {
  const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
  if (sentences.length <= 2) return [text];
  if (sentences.length <= 4) {
    // 3-4 sentences: split into 2 paragraphs
    const mid = Math.ceil(sentences.length / 2);
    return [
      sentences.slice(0, mid).join("").trim(),
      sentences.slice(mid).join("").trim(),
    ].filter(Boolean);
  }
  // 5+ sentences: split into 3 paragraphs
  const third = Math.ceil(sentences.length / 3);
  return [
    sentences.slice(0, third).join("").trim(),
    sentences.slice(third, third * 2).join("").trim(),
    sentences.slice(third * 2).join("").trim(),
  ].filter(Boolean);
}

const paragraphs = splitIntoParagraphs(writeup);

const isPublished = book.status === "published";
const bookUrl = `/discover/${book.slug}/`;
---

<article class="flex flex-col md:flex-row gap-8 md:gap-10 items-start pb-8 md:pb-16" id={`recommendation-${rank}`}>
  {/* Cover Image */}
  <div class="w-48 md:w-1/3 shrink-0 self-center md:self-start md:sticky md:top-24">
    <div class="aspect-[2/3] bg-[#efeeea] rounded-lg overflow-hidden shadow-[0_8px_32px_-12px_rgba(27,28,26,0.15)] transition-transform hover:scale-[1.01]">
      {coverUrl ? (
        <img
          src={coverUrl}
          alt={`${book.title} by ${authorName} book cover`}
          loading={isLazyLoad ? "lazy" : "eager"}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="w-full h-full bg-[#e5e2dc] flex items-center justify-center p-6">
          <span class="font-serif text-[#404943] text-center text-sm">{book.title}</span>
        </div>
      )}
    </div>
  </div>

  {/* Content */}
  <div class="flex-1 pt-0 md:pt-2">
    {/* Meta tags */}
    <div class="flex items-center gap-2 flex-wrap font-sans text-[10px] font-bold uppercase tracking-[0.15em] text-stone-500 mb-3">
      {year && (
        <span class="bg-stone-200/50 px-2 py-1 rounded-sm">{year}</span>
      )}
      {book.genres && book.genres.length > 0 && book.genres.map((genre: any) => (
        <a href={`/genre/${genre.slug}/`} class="bg-stone-200/50 px-2 py-1 rounded-sm hover:bg-stone-300/50 transition-colors no-underline text-stone-500 hover:text-[#0f5238]">{genre.name}</a>
      ))}
    </div>

    {/* Title */}
    <h3 class="font-serif text-2xl md:text-3xl font-bold leading-tight text-[#1C1917]">
      {isPublished ? (
        <a href={bookUrl} class="hover:text-[#0f5238] transition-colors no-underline">
          {book.title}
        </a>
      ) : (
        <span>{book.title}</span>
      )}
    </h3>

    {/* Author - only link if book is published (author will have a page) */}
    <p class="font-serif italic text-[#404943] mt-1">
      by {book.author?.slug && isPublished ? (
        <a href={`/author/${book.author.slug}/`} class="hover:text-[#0f5238] transition-colors no-underline hover:underline">{authorName}</a>
      ) : (
        <span>{authorName}</span>
      )}
    </p>

    {/* Why It's Similar label */}
    <div class="mt-5">
      <span class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#2D6A4F]">Why It's Similar</span>
    </div>

    {/* Writeup */}
    <div class="font-serif text-base md:text-lg text-[#404943] leading-relaxed space-y-4 mt-3">
      {paragraphs.map((para) => (
        <p>{para}</p>
      ))}
    </div>

    {/* Common Elements */}
    {commonElements && commonElements.length > 0 && (
      <div class="border-l-2 border-[#2D6A4F]/20 pl-4 py-1 mt-6 space-y-3">
        <h4 class="font-sans text-[11px] font-bold uppercase tracking-widest text-[#404943]">
          Elements in Common{parentBookTitle ? ` with ${parentBookTitle}` : ""}
        </h4>
        <ul class="space-y-2">
          {commonElements.map((element) => (
            <li class="text-sm font-serif text-[#404943] italic">
              &#8226; {element}
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* Action buttons */}
    <div class="flex flex-col md:flex-row items-stretch md:items-center gap-4 md:gap-6 mt-6">
      {isPublished && (
        <a
          href={bookUrl}
          class="text-[#0f5238] font-sans text-xs uppercase tracking-widest font-bold border-b border-transparent hover:border-[#0f5238] pb-1 transition-all text-center md:text-left"
        >
          Read Review
        </a>
      )}
      {book.amazonAffiliateLink && (
        <a
          href={book.amazonAffiliateLink}
          target="_blank"
          rel="nofollow noopener sponsored"
          class="text-[#954912] font-sans text-xs uppercase tracking-widest font-bold border border-[#954912] px-4 py-2 hover:bg-[#954912] hover:text-white transition-all rounded-sm text-center"
        >
          Amazon Store
        </a>
      )}
    </div>
  </div>
</article>
