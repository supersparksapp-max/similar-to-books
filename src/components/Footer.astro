---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: "About", href: "/about" },
  { label: "Privacy", href: "/privacy" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="border-t border-outline-variant/30 bg-surface-container-low mt-20">
  <div class="max-w-7xl mx-auto px-8 py-16">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      {/* Copyright */}
      <p class="font-sans text-[10px] tracking-[0.2em] uppercase text-on-surface-variant text-center md:text-left">
        &copy; {currentYear} Similar To Books. All rights reserved.
      </p>

      {/* Nav links */}
      <nav class="flex items-center justify-center md:justify-end gap-8" aria-label="Footer navigation">
        {footerLinks.map((link) => (
          <a
            href={link.href}
            class="font-sans text-[10px] tracking-[0.2em] uppercase text-on-surface-variant no-underline hover:text-primary-container transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    {/* Amazon affiliate disclaimer */}
    <p class="mt-10 font-sans text-[11px] leading-relaxed text-outline text-center md:text-left max-w-xl">
      As an Amazon Associate, we may earn from qualifying purchases. Book
      recommendations are editorial and independent.
    </p>
  </div>
</footer>
