---
const currentYear = new Date().getFullYear();
---

<footer class="w-full mt-20 bg-[#F5F3EF] border-t border-[#bfc9c1]/20">
  <div class="flex flex-col md:flex-row justify-between items-center px-8 py-16 max-w-7xl mx-auto gap-8">
    <div>
      <p class="font-sans text-[10px] tracking-[0.2em] uppercase font-medium text-[#1C1917]/50">
        &copy; {currentYear} SIMILAR TO BOOKS. ALL RIGHTS RESERVED.
      </p>
      <p class="font-sans text-[10px] text-[#1C1917]/30 mt-2">
        As an Amazon Associate, we earn from qualifying purchases.
      </p>
    </div>
    <nav class="flex gap-8">
      <a href="#" class="font-sans text-[10px] tracking-[0.2em] uppercase font-medium text-[#1C1917]/50 hover:text-[#2D6A4F] transition-colors">About</a>
      <a href="#" class="font-sans text-[10px] tracking-[0.2em] uppercase font-medium text-[#1C1917]/50 hover:text-[#2D6A4F] transition-colors">Privacy</a>
      <a href="#" class="font-sans text-[10px] tracking-[0.2em] uppercase font-medium text-[#1C1917]/50 hover:text-[#2D6A4F] transition-colors">Contact</a>
    </nav>
  </div>
</footer>
