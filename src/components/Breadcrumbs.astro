---
import { generateBreadcrumbSchema } from "../utils/seo";

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schemaItems = items.map((item) => ({
  name: item.label,
  url: item.href.startsWith("http")
    ? item.href
    : `https://www.similartobooks.com${item.href}`,
}));

const breadcrumbSchema = generateBreadcrumbSchema(schemaItems);
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1 list-none p-0 m-0">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-1 font-sans text-xs tracking-widest uppercase">
          {index > 0 && (
            <span class="text-outline-variant mx-1" aria-hidden="true">/</span>
          )}
          {index === items.length - 1 ? (
            <span class="text-on-surface-variant" aria-current="page">
              {item.label}
            </span>
          ) : (
            <a
              href={item.href}
              class="text-on-surface-variant no-underline hover:text-primary-container transition-colors"
            >
              {item.label}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<script
  type="application/ld+json"
  set:html={JSON.stringify(breadcrumbSchema)}
/>
